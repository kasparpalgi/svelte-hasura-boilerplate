# Public environment variables (exposed to client)
PUBLIC_API_ENV="development" # production / development
PUBLIC_API_ENDPOINT="https://your-hasura.example.com/v1/graphql"
PUBLIC_API_ENDPOINT_DEV="http://localhost:3001/v1/graphql"

# Controls which auth UI buttons are shown
PUBLIC_HAS_GOOGLE_AUTH=""   # true = show Google sign-in button
PUBLIC_HAS_EMAIL_AUTH="true"    # true = show magic link option

# Server-side only (used by codegen and server routes)
API_ENDPOINT="https://your-hasura.example.com/v1/graphql"
API_ENDPOINT_DEV="http://localhost:3001/v1/graphql"
HASURA_ADMIN_SECRET="your_secure_password_here"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your_auth_secret_here" # Must be same as in /hasura/.env
# AUTH_URL: not needed in dev (SvelteKit auto-detects). Set in production behind a proxy:
# AUTH_URL="https://yourdomain.com"

# Optional: Google OAuth (leave blank to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email / SMTP (required for magic link auth, email-change confirmation, etc email features)
# Gmail SMTP setup:
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Create an App Password for "Mail" — use it as EMAIL_SERVER_PASSWORD
# Leaving EMAIL_SERVER_HOST blank disables email features (magic link + email change).
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="you@gmail.com"
EMAIL_SERVER_PASSWORD="your-gmail-app-password"
EMAIL_FROM="Your App <you@gmail.com>"
