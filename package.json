{
	"name": "svelte-hasura-boilerplate",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=10.0.0"
	},
	"scripts": {
		"generate": "graphql-codegen --config codegen.ts",
		"dev": "npm run generate && vite dev",
		"build": "vite build",
		"b": "vite build && tar -czf deploy.tar.gz Dockerfile package.json package-lock.json svelte.config.js vite.config.ts tsconfig.json src static build .dockerignore",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "cross-env NODE_OPTIONS='--max-old-space-size=4096' svelte-kit sync && cross-env NODE_OPTIONS='--max-old-space-size=4096' svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "cross-env NODE_OPTIONS='--max-old-space-size=4096' svelte-kit sync && cross-env NODE_OPTIONS='--max-old-space-size=4096' svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --project=client",
		"test:unit:server": "vitest --project=server",
		"test:unit:all": "vitest",
		"test:unit:ui": "vitest --ui --project=client",
		"test": "npm run test:unit:all -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:h": "playwright test --headed --workers=1",
		"i-npm": "npm install -g npm@latest",
		"cu": "rm -rf node_modules .svelte-kit && npm cache clean --force && npm i",
		"cw": "rmdir /s /q node_modules && rmdir /s /q .svelte-kit && npm cache clean --force && npm i"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^9.8.0",
		"@graphql-codegen/cli": "^6.2.1",
		"@graphql-codegen/client-preset": "^5.2.4",
		"@lucide/svelte": "^0.544.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/svelte": "^5.2.8",
		"@types/bcryptjs": "^2.4.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/ui": "^4.1.0",
		"bits-ui": "^2.11.0",
		"clsx": "^2.1.1",
		"cross-env": "^10.0.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^27.0.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.0.7",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.3.8",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@auth/hasura-adapter": "^1.10.0",
		"@auth/sveltekit": "^1.10.0",
		"@neoconfetti/svelte": "^2.2.2",
		"@neodrag/svelte": "^2.3.3",
		"@simplewebauthn/browser": "^9.0.1",
		"@simplewebauthn/server": "^9.0.3",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltekit-i18n/parser-default": "^1.1.1",
		"bcryptjs": "^3.0.3",
		"date-fns": "^4.1.0",
		"dotenv": "^17.4.0",
		"graphql": "^16.13.2",
		"graphql-request": "^7.4.0",
		"jsonwebtoken": "^9.0.3",
		"mode-watcher": "^1.1.0",
		"sveltekit-i18n": "^2.4.2",
		"zod": "^4.1.11"
	}
}
